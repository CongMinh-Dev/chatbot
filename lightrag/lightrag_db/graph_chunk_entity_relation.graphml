<node id="Cruz's vision of control and order">
  <data key="d0">Cruz's vision of control and order</data>
  <data key="d1">concept</data>
  <data key="d2">This concept refers to Cruz's restrictive and authoritative approach towards the dynamics among other characters.</data>
  <data key="d3">chunk-0abb0129adb180938767353fab8e8f66</data>
