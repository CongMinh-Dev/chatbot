<node id="Nhà cây nhiều tầng bọc vải nỉ">
  <data key="d0">Nhà cây nhiều tầng bọc vải nỉ</data>
  <data key="d1">artifact</data>
  <data key="d2">Nhà cây nhiều tầng bọc vải nỉ là một sản phẩm hỗ trợ thú cưng giải tỏa căng thẳng, tập thể dục và hạn chế cào phá đồ đạc trong nhà.</data>
  <data key="d3">chunk-0abb0129adb180938767353fab8e8f66</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780737464</data>
