  <data key="d0">Viện Cây ăn quả miền Nam</data>
  <data key="d1">organization</data>
  <data key="d2">Viện Cây ăn quả miền Nam (SOFRI) là một tổ chức nghiên cứu về cây ăn quả.</data>
  <data key="d3">chunk-33b72e294f49b796c9b1fbddeeac87a0</data>
