<node id="Sầu riêng">
  <data key="d0">Sầu riêng</data>
  <data key="d1">species</data>
  <data key="d2">Sầu riêng (Durio zibethinus Murr.) là một loại cây ăn quả có giá trị kinh tế cao tại Việt Nam.</data>
  <data key="d3">chunk-33b72e294f49b796c9b1fbddeeac87a0</data>
