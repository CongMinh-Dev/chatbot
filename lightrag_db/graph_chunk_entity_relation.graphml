</node>
<node id="phân hữu cơ vi sinh">
  <data key="d0">phân hữu cơ vi sinh</data>
  <data key="d1">artifact</data>
  <data key="d2">Phân hữu cơ vi sinh là một loại phân bón được đề xuất sử dụng trong nghiên cứu này.&lt;SEP&gt;Phân hữu cơ vi sinh là một công thức đối chứng trong thí nghiệm về việc bón phân cho cây sầu riêng 7 năm tuổi.&lt;SEP&gt;Phân hữu cơ vi sinh là một trong các loại phân bón sử dụng trong thí nghiệm, hàm lượng OM ≥ 15% và mật độ vi sinh vật có ích ≥ 1 × 106 CFU/g.</data>
  <data key="d3">chunk-33b72e294f49b796c9b1fbddeeac87a0&lt;SEP&gt;chunk-a8221763d1ce4a9767d04bcabd68c16e&lt;SEP&gt;chunk-c28c928c92c33474c6225b6141933c7e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403892</data>
  <data key="d6"></data>
</node>
<node id="phân khoáng NPK tối ưu">
  <data key="d0">phân khoáng NPK tối ưu</data>
  <data key="d1">artifact</data>
  <data key="d2">Phân khoáng NPK tối ưu cũng là một loại phân bón được đề xuất sử dụng trong nghiên cứu này.</data>
  <data key="d3">chunk-33b72e294f49b796c9b1fbddeeac87a0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403706</data>
  <data key="d6"></data>
</node>
