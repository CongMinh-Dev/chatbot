  <data key="d0">chất trái sầu riêng Ri6</data>
  <data key="d1">artifact</data>
  <data key="d2">Chất trái sầu riêng Ri6 là một đối chứng trong thí nghiệm về việc bón phân cho cây sầu riêng.</data>
  <data key="d3">chunk-a8221763d1ce4a9767d04bcabd68c16e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403743</data>
  <data key="d6"></data>
</node>
