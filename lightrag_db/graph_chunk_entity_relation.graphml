<graph edgedefault="undirected"><node id="TẠP CHÍ KHOA HỌC CÔNG NGHỆ NÔNG NGHIỆP VIỆT NAM">
  <data key="d0">TẠP CHÍ KHOA HỌC CÔNG NGHỆ NÔNG NGHIỆP VIỆT NAM</data>
  <data key="d1">publication</data>
  <data key="d2">Tạp chí Khoa học Công nghệ nông nghiệp Việt Nam là một tạp chí khoa học chuyên về công nghệ nông nghiệp.</data>
  <data key="d3">chunk-cdef2a60c00766ca5c2ccd01c3e98b2b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403683</data>
