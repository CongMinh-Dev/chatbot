  <data key="d0">Đất</data>
  <data key="d1">artifact</data>
  <data key="d2">đất là nơi chứa chất hữu cơ và độ phì của nó được nghiên cứu.&lt;SEP&gt;đất là vật liệu nền cho nông nghiệp, nơi thực hiện các thí nghiệm và phân tích.</data>
  <data key="d3">chunk-0bf2a02a6dbba1ffe7070a96338717f7&lt;SEP&gt;chunk-f95ced4f447334b64417538cb44fd21a</data>
