<graph edgedefault="undirected"><node id="Nguyễn Văn Hùng">
  <data key="d0">Nguyễn Văn Hùng</data>
  <data key="d1">person</data>
  <data key="d2">Nguyễn Văn Hùng là tác giả chính của nghiên cứu về ảnh hưởng của chế độ phân bón tích hợp đến năng suất, chất lượng và hàm lượng dinh dưỡng đất trong canh tác sầu riêng.</data>
  <data key="d3">chunk-cdef2a60c00766ca5c2ccd01c3e98b2b</data>
