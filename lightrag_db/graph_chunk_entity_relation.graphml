<node id="Bioline">
  <data key="d0">Bioline</data>
  <data key="d1">artifact</data>
  <data key="d2">Men vi sinh xử lý tiêu hóa Bioline là sản phẩm dạng bột hòa tan chứa lợi khuẩn đường ruột giúp điều trị các chứng tiêu chảy, phân lỏng, đầy hơi và ổn định hệ vi sinh đường ruột.</data>
  <data key="d3">chunk-449c21590adb1384a8c243bab42ded52</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780719595</data>
  <data key="d6"></data>
</node>
