<node id="phân bón vô cơ">
  <data key="d0">phân bón vô cơ</data>
  <data key="d1">artifact</data>
  <data key="d2">Phân bón vô cơ được đề cập đến như là nguyên nhân gây suy thoái đất và giảm chất lượng trái sầu riêng.</data>
  <data key="d3">chunk-33b72e294f49b796c9b1fbddeeac87a0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403706</data>
