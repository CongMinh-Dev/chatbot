</node>
<node id="Lê Hoàng Nam">
  <data key="d0">Lê Hoàng Nam</data>
  <data key="d1">person</data>
  <data key="d2">Lê Hoàng Nam là tác giả thuộc Viện Cây ăn quả miền Nam (SOFRI) tham gia nghiên cứu về sầu riêng.</data>
  <data key="d3">chunk-cdef2a60c00766ca5c2ccd01c3e98b2b</data>
  <data key="d4">unknown_source</data>
