</node>
<node id="Trần Thị Mai">
  <data key="d0">Trần Thị Mai</data>
  <data key="d1">person</data>
  <data key="d2">Trần Thị Mai là một trong những tác giả của nghiên cứu trên tạp chí khoa học công nghệ nông nghiệp Việt Nam số 04/2026.</data>
  <data key="d3">chunk-cdef2a60c00766ca5c2ccd01c3e98b2b</data>
  <data key="d4">unknown_source</data>
