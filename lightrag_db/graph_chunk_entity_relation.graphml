  <data key="d1">experiment</data>
  <data key="d2">NT1 là đối chứng với trọng lượng trái là 2,85 kg, năng suất thực tế là 18,9 tấn/ha, độ Brix là 19,5%, và tỷ lệ sượng trái là 8,4%.</data>
  <data key="d3">chunk-a917d903439a77eea4cdc1887047d41b</data>
