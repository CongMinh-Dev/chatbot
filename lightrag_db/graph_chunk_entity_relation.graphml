</node>
<node id="tỉnh Vĩnh Long">
  <data key="d0">tỉnh Vĩnh Long</data>
  <data key="d1">location</data>
  <data key="d2">Tỉnh Vĩnh Long là nơi thực hiện thí nghiệm về việc bón phân cho cây sầu riêng.&lt;SEP&gt;Tỉnh Vĩnh Long bao gồm huyện Vũng Liêm và là nơi trồng sầu riêng Ri6.</data>
  <data key="d3">chunk-a8221763d1ce4a9767d04bcabd68c16e&lt;SEP&gt;chunk-c28c928c92c33474c6225b6141933c7e</data>
