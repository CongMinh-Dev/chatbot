</node>
<node id="Số 04/2026">
  <data key="d0">Số 04/2026</data>
  <data key="d1">data</data>
  <data key="d2">Số 04/2026 của Tạp chí Khoa học Công nghệ Nông nghiệp Việt Nam chứa nghiên cứu về ảnh hưởng của chế độ phân bón tích hợp đến canh tác sầu riêng.</data>
  <data key="d3">chunk-cdef2a60c00766ca5c2ccd01c3e98b2b</data>
