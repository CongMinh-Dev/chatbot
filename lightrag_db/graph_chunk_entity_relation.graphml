  <data key="d0">lượng chất hữu cơ (OM) trong đất</data>
  <data key="d1">concept</data>
  <data key="d2">lượng chất hữu cơ (OM) trong đất tăng từ 2,1% lên 3,4%, tỷ lệ sượng trái giảm đáng kể xuống dưới 3%.</data>
  <data key="d3">chunk-0bf2a02a6dbba1ffe7070a96338717f7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403775</data>
