  <data key="d0">RCBD</data>
  <data key="d1">method</data>
  <data key="d2">RCBD (Khối hoàn toàn ngẫu nhiên) là phương pháp bố trí thí nghiệm được sử dụng trong nghiên cứu.</data>
  <data key="d3">chunk-a8221763d1ce4a9767d04bcabd68c16e&lt;SEP&gt;chunk-8ec606c812acdadaee8cf51356973084</data>
  <data key="d4">unknown_source</data>
