</node>
<node id="NPK">
  <data key="d0">NPK</data>
  <data key="d1">concept</data>
  <data key="d2">NPK (Nitrogen-Phosphorus-Potassium) được đề cập trong thí nghiệm, mặc dù không chi tiết về cách sử dụng.</data>
  <data key="d3">chunk-a8221763d1ce4a9767d04bcabd68c16e</data>
