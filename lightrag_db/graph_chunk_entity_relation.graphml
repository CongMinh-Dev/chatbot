  <data key="d0">độ phì nhiêu của đất</data>
  <data key="d1">concept</data>
  <data key="d2">Độ phì nhiêu của đất được nghiên cứu trong thí nghiệm liên quan đến việc bón phân cho cây sầu riêng 7 năm tuổi.</data>
  <data key="d3">chunk-a8221763d1ce4a9767d04bcabd68c16e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1780403743</data>
