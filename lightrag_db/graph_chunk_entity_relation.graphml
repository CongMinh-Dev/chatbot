  <data key="d1">category</data>
  <data key="d2">Thời điểm thu hoạch là một yếu tố quan trọng để đánh giá năng suất và chất lượng trái cây.</data>
  <data key="d3">chunk-8f71153619528c78d90620e631e39af1</data>
